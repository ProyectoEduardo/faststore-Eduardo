  [
    {
      "name": "CallToAction",
      "schema": {
        "title": "Call To Action",
        "description": "Get your 20% off on the first purchase!",
        "type": "object",
        "required": [
          "title",
          "link"
        ],
        "properties": {
          "title": {
            "title": "Title",
            "type": "string"
          },
          "link": {
            "title": "Link Path",
            "type": "object",
            "required": [
              "text",
              "url"
            ],
            "properties": {
              "text": {
                "title": "Text",
                "type": "string"
              },
              "url": {
                "title": "URL",
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "name": "HelloWorld",
      "schema": {
        "title": "Hello World",
        "description": "Sección mínima para pruebas",
        "type": "object",
        "required": [
          "title",
          "text"
        ],
        "properties": {
          "title": {
            "title": "Título",
            "type": "string"
          },
          "text": {
            "title": "Texto",
            "type": "string"
          }
        }
      }
    },
    {
      "name": "CustomHeader",
      "schema": {
        "title": "Custom Header",
        "description": "Header propio con logo, search, login, CTA, minicart y links",
        "type": "object",
        "required": [
          "logoText",
          "searchPlaceholder",
          "loginLabel",
          "actionLabel",
          "minicartLabel"
        ],
        "properties": {
          "logoText": {
            "title": "Logo Text",
            "type": "string",
            "default": "Brandless"
          },
          "searchPlaceholder": {
            "title": "Search Placeholder",
            "type": "string",
            "default": "Search everything in the store"
          },
          "loginLabel": {
            "title": "Login Label",
            "type": "string",
            "default": "Sign in"
          },
          "icon": {
            "title": "Login Icon",
            "type": "string",
            "enum": [
              "User",
              "Heart",
              "Bell"
            ],
            "enumNames": [
              "User",
              "Heart",
              "Bell"
            ],
            "default": "User"
          },
          "actionLabel": {
            "title": "Action Button Label",
            "type": "string",
            "default": "Benefits"
          },
          "minicartLabel": {
            "title": "Minicart Label",
            "type": "string",
            "default": "Cart"
          },
          "links": {
            "title": "Bottom Links",
            "type": "array",
            "items": {
              "title": "Link",
              "type": "object",
              "required": [
                "label",
                "href"
              ],
              "properties": {
                "label": {
                  "title": "Label",
                  "type": "string"
                },
                "href": {
                  "title": "Href",
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "ProductShowcase",
      "requiredScopes": [
        "global",
        "home",
        "landing"
      ],
      "schema": {
        "title": "Product Showcase",
        "description": "Prueba mínima de colección",
        "type": "object",
        "properties": {
          "title": {
            "title": "Título",
            "type": "string",
            "default": "Productos destacados"
          },
          "productClusterIds": {
            "title": "Collection ID",
            "type": "string"
          },
          "first": {
            "title": "Cantidad de productos",
            "type": "number",
            "default": 5
          }
        },
        "required": [
          "productClusterIds"
        ]
      }
    }
  ]