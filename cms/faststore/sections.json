[
  {
    "name": "CallToAction",
    "schema": {
      "title": "Call To Action",
      "description": "Get your 20% off on the first purchase!",
      "type": "object",
      "required": [
        "title",
        "link"
      ],
      "properties": {
        "title": {
          "title": "Title",
          "type": "string"
        },
        "link": {
          "title": "Link Path",
          "type": "object",
          "required": [
            "text",
            "url"
          ],
          "properties": {
            "text": {
              "title": "Text",
              "type": "string"
            },
            "url": {
              "title": "URL",
              "type": "string"
            }
          }
        }
      }
    }
  },
  {
    "name": "HelloWorld",
    "schema": {
      "title": "Hello World",
      "description": "Sección mínima para pruebas",
      "type": "object",
      "required": [
        "title",
        "text"
      ],
      "properties": {
        "title": {
          "title": "Título",
          "type": "string"
        },
        "text": {
          "title": "Texto",
          "type": "string"
        }
      }
    }
  },
  {
    "name": "CustomHeader",
    "schema": {
      "title": "Custom Header",
      "description": "Header propio con logo, search, login, CTA, minicart y links",
      "type": "object",
      "required": [
        "logoText",
        "searchPlaceholder",
        "loginLabel",
        "actionLabel",
        "minicartLabel"
      ],
      "properties": {
        "logoText": {
          "title": "Logo Text",
          "type": "string",
          "default": "Brandless"
        },
        "searchPlaceholder": {
          "title": "Search Placeholder",
          "type": "string",
          "default": "Search everything in the store"
        },
        "loginLabel": {
          "title": "Login Label",
          "type": "string",
          "default": "Sign in"
        },
        "icon": {
          "title": "Login Icon",
          "type": "string",
          "enum": [
            "User",
            "Heart",
            "Bell"
          ],
          "enumNames": [
            "User",
            "Heart",
            "Bell"
          ],
          "default": "User"
        },
        "actionLabel": {
          "title": "Action Button Label",
          "type": "string",
          "default": "Benefits"
        },
        "minicartLabel": {
          "title": "Minicart Label",
          "type": "string",
          "default": "Cart"
        },
        "links": {
          "title": "Menu Links",
          "type": "array",
          "items": {
            "title": "Menu Item",
            "type": "object",
            "required": [
              "label"
            ],
            "properties": {
              "label": {
                "title": "Label",
                "type": "string"
              },
              "href": {
                "title": "Href",
                "type": "string"
              },
              "children": {
                "title": "Submenu",
                "type": "array",
                "items": {
                  "title": "Submenu Item",
                  "type": "object",
                  "required": [
                    "label",
                    "href"
                  ],
                  "properties": {
                    "label": {
                      "title": "Label",
                      "type": "string"
                    },
                    "href": {
                      "title": "Href",
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  {
    "name": "ProductShowcase",
    "requiredScopes": [
      "global",
      "home",
      "landing"
    ],
    "schema": {
      "title": "Product Showcase",
      "description": "Prueba mínima de colección",
      "type": "object",
      "properties": {
        "title": {
          "title": "Título",
          "type": "string",
          "default": "Productos destacados"
        },
        "productClusterIds": {
          "title": "Collection ID",
          "type": "string"
        },
        "first": {
          "title": "Cantidad de productos",
          "type": "number",
          "default": 5
        }
      },
      "required": [
        "productClusterIds"
      ]
    }
  },
  {
    "name": "CustomSlider",
    "schema": {
      "title": "Custom Slider",
      "description": "Slider de imágenes con animación",
      "type": "object",
      "properties": {
        "autoplay": {
          "title": "Autoplay",
          "type": "boolean",
          "default": true
        },
        "interval": {
          "title": "Interval (ms)",
          "type": "number",
          "default": 4000
        },
        "slides": {
          "title": "Slides",
          "type": "array",
          "items": {
            "title": "Slide",
            "type": "object",
            "required": [
              "image"
            ],
            "properties": {
              "image": {
                "title": "Image URL",
                "type": "string",
                "widget": {
                  "ui:widget": "image-uploader"
                }
              },
              "link": {
                "title": "Link",
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  {
    "name": "CustomTicker",
    "schema": {
      "title": "Cintillo Promocional",
      "description": "Barra superior con texto configurable y animación",
      "type": "object",
      "properties": {
        "enabled": {
          "title": "Activar barra",
          "type": "boolean",
          "default": true
        },
        "text": {
          "title": "Texto",
          "type": "string",
          "default": "Envío gratis en compras mayores a S/199"
        },
        "backgroundColor": {
          "title": "Color de fondo",
          "type": "string",
          "default": "#000000"
        },
        "textColor": {
          "title": "Color de texto",
          "type": "string",
          "default": "#ffffff"
        },
        "animate": {
          "title": "Activar movimiento",
          "type": "boolean",
          "default": true
        },
        "duration": {
          "title": "Duración (segundos)",
          "type": "number",
          "default": 10
        }
      }
    }
  },
  {
    "name": "CategoryGrid",
    "schema": {
      "title": "Grid de Categorías",
      "description": "Bloque de categorías navegables con imagen",
      "type": "object",
      "properties": {
        "columns": {
          "title": "Columnas (desktop)",
          "type": "number",
          "default": 4
        },
        "items": {
          "title": "Categorías",
          "type": "array",
          "items": {
            "title": "Categoría",
            "type": "object",
            "required": [
              "title",
              "image",
              "link"
            ],
            "properties": {
              "title": {
                "title": "Título",
                "type": "string"
              },
              "image": {
                "title": "Imagen",
                "type": "string",
                "widget": {
                  "ui:widget": "image-uploader"
                }
              },
              "link": {
                "title": "Link",
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  {
    "name": "Newsletter",
    "schema": {
      "title": "Newsletter / Suscripción",
      "description": "Bloque de captura de correos",
      "type": "object",
      "properties": {
        "enabled": {
          "title": "Mostrar bloque",
          "type": "boolean",
          "default": true
        },
        "title": {
          "title": "Título",
          "type": "string"
        },
        "subtitle": {
          "title": "Subtítulo",
          "type": "string"
        },
        "backgroundColor": {
          "title": "Color de fondo",
          "type": "string",
          "default": "#f5f5f5"
        },
        "backgroundImage": {
          "title": "Imagen de fondo",
          "type": "string",
          "widget": {
            "ui:widget": "image-uploader"
          }
        },
        "buttonText": {
          "title": "Texto del botón",
          "type": "string",
          "default": "Suscribirme"
        },
        "successMessage": {
          "title": "Mensaje de éxito",
          "type": "string",
          "default": "¡Gracias por suscribirte!"
        },
        "errorMessage": {
          "title": "Mensaje de error",
          "type": "string",
          "default": "Correo inválido"
        }
      }
    }
  },
  {
    "name": "ProductDetail",
    "schema": {
      "title": "Product Detail",
      "description": "Detalle del producto usando contexto PDP",
      "type": "object",
      "properties": {
        "enabled": {
          "title": "Mostrar sección",
          "type": "boolean",
          "default": true
        },
        "buttonText": {
          "title": "Texto botón",
          "type": "string",
          "default": "Comprar"
        }
      }
    }
  }

]